# =============================================================
#  Main-Auth — .gitignore
# =============================================================

# ── Credentials & Environment ────────────────────────────────
# NEVER commit .env — it contains database passwords and SMTP keys.
# Each developer/server must create their own from .env.example
.env
.env.local
.env.*.local

# ── PHP / Backend ─────────────────────────────────────────────
# Composer vendor directory (not applicable yet but good practice)
/vendor/
composer.lock

# PHP error logs
php_error.log
error_log

# ── Frontend / Node ───────────────────────────────────────────
# Never commit node_modules — run `npm install` to restore
frontend/node_modules/

# Vite production build output — generated by `npm run build`
frontend/dist/

# Vite cache
frontend/.vite/

# npm debug logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# ── Test & Debug Files ────────────────────────────────────────
cookie.txt
test_cookie.txt
*.cookie.txt
smtp_test.php
remove_bom.php

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# ── Operating System ──────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
