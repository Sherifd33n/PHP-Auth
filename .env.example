# Copy this file to .env and fill in your own values.
# DO NOT commit .env — it contains real credentials.

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=login_register

# ── Email (SMTP) ──────────────────────────────────────────────
# For development: sign up free at https://mailtrap.io
# Go to: Email Testing → Inboxes → My Inbox → SMTP Settings
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=no-reply@main-auth.dev
MAIL_FROM_NAME=Main Auth

# ── Application ───────────────────────────────────────────────
# Base URL of the React frontend (used to build password reset links)
APP_URL=http://localhost:5173
